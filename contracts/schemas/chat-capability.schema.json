{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/dsm-native-client/chat-capability.schema.json",
  "title": "ChatCapability",
  "type": "object",
  "additionalProperties": false,
  "required": ["status", "supportedFeatures"],
  "properties": {
    "status": {
      "type": "string",
      "enum": ["unavailable", "requiresValidation", "available"]
    },
    "supportedFeatures": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": [
          "directConversation",
          "groupConversation",
          "textMessage",
          "emoji",
          "imageAttachment",
          "videoAttachment",
          "fileAttachment",
          "voiceMessage",
          "reminder",
          "poll",
          "encryptedConversation"
        ]
      }
    }
  }
}
